<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/auto_forward_rule_holder"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/tiny_margin"
    android:clickable="true"
    android:focusable="true"
    android:paddingStart="@dimen/activity_margin"
    android:paddingTop="@dimen/medium_margin"
    android:paddingEnd="@dimen/activity_margin"
    android:paddingBottom="@dimen/medium_margin">

    <org.fossify.commons.views.MyMaterialSwitch
        android:id="@+id/auto_forward_rule_enabled"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true" />

    <ImageView
        android:id="@+id/auto_forward_rule_menu"
        style="@style/OverflowMenuIconStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_toStartOf="@id/auto_forward_rule_enabled" />

    <org.fossify.commons.views.MyTextView
        android:id="@+id/auto_forward_rule_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toStartOf="@id/auto_forward_rule_menu"
        android:textStyle="bold"
        android:textSize="@dimen/bigger_text_size"
        tools:text="Bank OTP" />

    <org.fossify.commons.views.MyTextView
        android:id="@+id/auto_forward_rule_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/auto_forward_rule_title"
        android:layout_marginTop="@dimen/tiny_margin"
        android:layout_toStartOf="@id/auto_forward_rule_menu"
        tools:text="Keywords -> SMS +15551234567" />
</RelativeLayout>
